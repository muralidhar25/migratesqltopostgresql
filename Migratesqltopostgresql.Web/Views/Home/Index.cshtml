@{
    ViewData["Title"] = "Migration Console";
}

<section class="migration-panel">
    <h1>SQL Server to PostgreSQL Migration</h1>
    <p class="subtitle">Enter source DB name and click migrate. Progress and errors are shown below.</p>

    <div class="field-row">
        <label for="dbname">Source DB Name</label>
        <input id="dbname" type="text" placeholder="Example: SalesDB" autocomplete="off" />
    </div>

    <div class="field-row">
        <label for="targetDbname">Target PostgreSQL DB Name (optional)</label>
        <input id="targetDbname" type="text" placeholder="Default: same as source" autocomplete="off" />
    </div>

    <button id="migrateBtn" class="migrate-btn" type="button">Migrate</button>

    <div class="progress-wrap" aria-live="polite">
        <div class="progress-head">
            <span>Progress</span>
            <span id="progressText">0%</span>
        </div>
        <div class="progress-track">
            <div id="progressBar" class="progress-fill"></div>
        </div>
        <p id="statusText" class="status-text">Idle</p>
    </div>

    <p id="errorText" class="error-text"></p>

    <div id="logBox" class="log-box"></div>

    <div class="comparison-section">
        <div class="comparison-actions">
            <button id="compareBtn" class="compare-btn" type="button">Compare Databases</button>
            <button id="clearCompareBtn" class="clear-btn hidden" type="button">Clear Comparison</button>
        </div>
        <div id="comparisonResults" class="comparison-results hidden"></div>
    </div>
</section>

<div id="connModal" class="conn-modal hidden" role="dialog" aria-modal="true" aria-labelledby="connModalTitle">
    <div class="conn-modal-card">

        <!-- ── STEP 1: SQL Server ──────────────────────────────────── -->
        <div id="stepSqlServer" class="conn-step">
            <div class="conn-step-header">
                <span class="conn-step-badge">Step 1 of 2</span>
                <h2 id="connModalTitle">SQL Server Connection</h2>
            </div>

            <div class="conn-format-box">
                <p class="conn-format-label">Expected format</p>
                <code>Server=&lt;host&gt;,&lt;port&gt;;Database=<strong>{dbname}</strong>;User Id=&lt;user&gt;;Password=&lt;password&gt;;Encrypt=True;TrustServerCertificate=True;</code>
                <p class="conn-format-note">You can use either <code>Database={dbname}</code> template format or a fixed database (for example <code>Database=cm_auth</code>). Azure AD (no password): use <code>Authentication=Active Directory Default;</code>.</p>
            </div>

            <label for="sqlServerTemplate">Your SQL Server Connection String <span class="req">({dbname} placeholder optional)</span></label>
            <textarea id="sqlServerTemplate" rows="4"
                placeholder="Server=cm2-0.public.e9bc597df61e.database.windows.net,3342;Database={dbname};Encrypt=True;TrustServerCertificate=True;Authentication=Active Directory Default;"></textarea>

            <div class="conn-test-row">
                <button id="sqlConnectBtn" type="button" class="connect-btn">Connect &amp; Test</button>
                <span id="sqlConnStatus" class="conn-status"></span>
            </div>
        </div>

        <!-- ── STEP 2: PostgreSQL ─────────────────────────────────── -->
        <div id="stepPostgres" class="conn-step hidden">
            <div class="conn-step-header">
                <span class="conn-step-badge">Step 2 of 2</span>
                <h2>PostgreSQL Connection</h2>
            </div>

            <div class="conn-format-box">
                <p class="conn-format-label">Expected format</p>
                <code>Host=&lt;host&gt;;Port=5432;Database=&lt;db&gt;;Username=&lt;user&gt;;Password=&lt;password&gt;;Ssl Mode=Require;</code>
            </div>

            <label for="postgresAdminConnection">Your PostgreSQL Admin Connection String</label>
            <textarea id="postgresAdminConnection" rows="4"
                placeholder="Host=your-pg-host;Port=5432;Database=postgres;Username=muralidhar;Password=your-password;Ssl Mode=Require;Trust Server Certificate=true;"></textarea>

            <div class="conn-test-row">
                <button id="pgConnectBtn" type="button" class="connect-btn">Connect &amp; Test</button>
                <span id="pgConnStatus" class="conn-status"></span>
            </div>

            <div class="migration-mode-section">
                <label class="migration-mode-label">Migration Mode <span class="req">(required)</span></label>
                <div class="migration-mode-options">
                    <label class="radio-option">
                        <input type="radio" name="migrationMode" value="schemaAndData" id="modeSchemaAndData" checked />
                        <div class="radio-content">
                            <strong>Schema + Data (Full Migration)</strong>
                            <p>Migrate table structures and all data</p>
                        </div>
                    </label>
                    <label class="radio-option">
                        <input type="radio" name="migrationMode" value="schemaOnly" id="modeSchemaOnly" />
                        <div class="radio-content">
                            <strong>Schema Only</strong>
                            <p>Create table structures without copying data</p>
                        </div>
                    </label>
                </div>
            </div>
        </div>

        <p id="connModalError" class="error-text"></p>

        <div class="conn-modal-actions">
            <button id="connCancelBtn" type="button" class="ghost-btn">Cancel</button>
            <button id="connBackBtn" type="button" class="ghost-btn hidden">&#8592; Back</button>
            <button id="connNextBtn" type="button" class="migrate-btn" disabled>Next &#8594;</button>
            <button id="connStartBtn" type="button" class="migrate-btn hidden" disabled>Start Migration</button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/migration.js" asp-append-version="true"></script>
}
